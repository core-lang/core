fun main(): Unit {
  let x = Int32::minValue().toStringHex();
  assert(x == "80000000");

  let x = Int32::maxValue().toStringHex();
  assert(x == "7FFFFFFF");

  let x = 0i32.toStringHex();
  assert(x == "0");

  let x = 12i32.toStringHex();
  assert(x == "C");

  let x = 67i32.toStringHex();
  assert(x == "43");

  let x = 129i32.toStringHex();
  assert(x == "81");

  let x = (-1i32).toStringHex();
  assert(x == "FFFFFFFF");

  let x = (-129i32).toStringHex();
  assert(x == "FFFFFF7F");
}
